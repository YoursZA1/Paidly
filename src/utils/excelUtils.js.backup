// Validate invoice data
export const validateInvoiceData = (data) => {
  const errors = [];
  const warnings = [];
  
  data.forEach((row, index) => {
    const rowNum = index + 2; // Excel row number (header is row 1)
    
    // Required fields
    if (!row['Invoice Number']) {
      errors.push(`Row ${rowNum}: Invoice Number is required`);
    }
    if (!row['Client Name']) {
      errors.push(`Row ${rowNum}: Client Name is required`);
    }
    if (!row['Project Title']) {
      errors.push(`Row ${rowNum}: Project Title is required`);
    }
    
    // Numeric validations
    if (row['Quantity'] && isNaN(row['Quantity'])) {
      errors.push(`Row ${rowNum}: Quantity must be a number`);
    }
    if (row['Unit Price'] && isNaN(row['Unit Price'])) {
      errors.push(`Row ${rowNum}: Unit Price must be a number`);
    }
    if (row['Tax Rate (%)'] && isNaN(row['Tax Rate (%)'])) {
      errors.push(`Row ${rowNum}: Tax Rate must be a number`);
    }
    
    // Date validations
    if (row['Invoice Date'] && !isValidDate(row['Invoice Date'])) {
      errors.push(`Row ${rowNum}: Invalid Invoice Date format`);
    }
    if (row['Due Date'] && !isValidDate(row['Due Date'])) {
      errors.push(`Row ${rowNum}: Invalid Due Date format`);
    }
    
    // Status validation
    const validStatuses = ['draft', 'sent', 'paid', 'overdue', 'cancelled'];
    if (row['Status'] && !validStatuses.includes(row['Status'].toLowerCase())) {
      warnings.push(`Row ${rowNum}: Status should be one of: ${validStatuses.join(', ')}`);
    }
  });
  
  return {
    isValid: errors.length === 0,
    errors,
    warnings,
    totalRows: data.length
  };
};

// Validate client data
export const validateClientData = (data) => {
  const errors = [];
  const warnings = [];
  
  data.forEach((row, index) => {
    const rowNum = index + 2;
    
    if (!row['Client Name']) {
      errors.push(`Row ${rowNum}: Client Name is required`);
    }
    
    if (row['Email'] && !isValidEmail(row['Email'])) {
      errors.push(`Row ${rowNum}: Invalid email format`);
    }
    
    if (!row['Email'] && !row['Phone']) {
      warnings.push(`Row ${rowNum}: No contact information (email or phone)`);
    }
  });
  
  return {
    isValid: errors.length === 0,
    errors,
    warnings,
    totalRows: data.length
  };
};

// Validate service data
export const validateServiceData = (data) => {
  const errors = [];
  const warnings = [];
  
  data.forEach((row, index) => {
    const rowNum = index + 2;
    
    if (!row['Service Name']) {
      errors.push(`Row ${rowNum}: Service Name is required`);
    }
    
    if (row['Default Price'] && isNaN(row['Default Price'])) {
      errors.push(`Row ${rowNum}: Default Price must be a number`);
    }
    
    if (row['Tax Rate (%)'] && isNaN(row['Tax Rate (%)'])) {
      errors.push(`Row ${rowNum}: Tax Rate must be a number`);
    }
  });
  
  return {
    isValid: errors.length === 0,
    errors,
    warnings,
    totalRows: data.length
  };
};

// Helper functions
const isValidDate = (dateString) => {
  const date = new Date(dateString);
  return date instanceof Date && !isNaN(date);
};

const isValidEmail = (email) => {
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  return emailRegex.test(email);
};

// Export existing invoices to Excel
export const exportInvoices = (invoices, clients) => {
  const data = invoices.map(invoice => {
    const client = clients.find(c => c.id === invoice.client_id);
    return {
      'Invoice Number': invoice.invoice_number,
      'Client Name': client?.name || 'Unknown',
      'Project Title': invoice.project_title,
      'Project Description': invoice.project_description,
      'Invoice Date': invoice.invoice_date || invoice.created_date,
      'Due Date': invoice.delivery_date,
      'Subtotal': invoice.subtotal,
      'Tax Amount': invoice.tax_amount,
      'Total Amount': invoice.total_amount,
      'Status': invoice.status,
      'Created Date': invoice.created_date,
      'Notes': invoice.notes
    };
  });
  
  return exportToExcel(data, 'invoices_export.xlsx', 'Invoices');
};

// Export existing clients to Excel
export const exportClients = (clients) => {
  const data = clients.map(client => ({
    'Client Name': client.name,
    'Email': client.email,
    'Phone': client.phone,
    'Address': client.address,
    'Tax Number': client.tax_number,
    'Contact Person': client.contact_person,
    'Created Date': client.created_date,
    'Notes': client.notes
  }));
  
  return exportToExcel(data, 'clients_export.xlsx', 'Clients');
};

// Export existing services to Excel
export const exportServices = (services) => {
  const data = services.map(service => ({
    'Service Name': service.name,
    'Description': service.description,
    'Default Price': service.default_price,
    'Unit': service.unit,
    'Tax Rate (%)': service.tax_rate,
    'Category': service.category,
    'Created Date': service.created_date
  }));
  
  return exportToExcel(data, 'services_export.xlsx', 'Services');
};

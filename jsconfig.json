{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "server/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".vercel",
    "coverage"
  ]
} 
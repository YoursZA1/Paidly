# ===========================================
# DEVELOPMENT – Frontend environment (Vite)
# ===========================================
# Copy to .env.development or .env and fill in.
# Used when running: npm run dev (mode = development)
# Use a DEV or STAGING Supabase project only. Never use production here.
# See: docs/SUPABASE_SETUP_AND_MAINTENANCE.md

# Backend API (local dev server)
VITE_SERVER_URL=http://localhost:5179

# Supabase – DEV/STAGING project (anon key only; service role never on frontend)
# Dashboard → your dev/staging project → Settings → API → Project URL + anon public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Storage bucket (optional; default: invoicebreek)
VITE_SUPABASE_STORAGE_BUCKET=invoicebreek

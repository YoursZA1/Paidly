# ===========================================
# PRODUCTION – Frontend environment (Vite)
# ===========================================
# Copy to .env.production or set in your host’s env (Vercel, Netlify, etc.).
# Used when running: npm run build (mode = production)
#
# IMPORTANT: Use a dedicated PRODUCTION Supabase project. The values below are
# PLACEHOLDERS. Replace them with your real production URL and anon key before
# deploying. Never commit real keys to git; set them in your host’s environment.
# See: docs/SUPABASE_SETUP_AND_MAINTENANCE.md
#
# Vercel/Netlify: Project → Settings → Environment Variables. Add for Production
# (and Preview if needed), then redeploy. Add your app URL in Supabase →
# Authentication → URL Configuration (Site URL & Redirect URLs).

# Backend API (production URL – set in host env or here)
VITE_SERVER_URL=https://your-backend-api.vercel.app

# Supabase – PRODUCTION project only (anon key only; service role NEVER on frontend)
# Get from: Supabase Dashboard → Your production project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_production_anon_key_here

# Storage bucket (optional; default: invoicebreek)
VITE_SUPABASE_STORAGE_BUCKET=invoicebreek

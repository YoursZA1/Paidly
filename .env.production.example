# ===========================================
# PRODUCTION – Frontend environment (Vite)
# ===========================================
# Copy to .env.production or set in your host’s env (Vercel, Netlify, etc.).
# Used when running: npm run build (mode = production)
# Use a dedicated PRODUCTION Supabase project only.
# See: docs/SUPABASE_SETUP_AND_MAINTENANCE.md
#
# Vercel: Project → Settings → Environment Variables. Add VITE_SUPABASE_URL and
# VITE_SUPABASE_ANON_KEY for Production (and Preview if needed), then redeploy.
#
# Production app URL: https://invoicebreekapp2.vercel.app
# Add this URL in Supabase → Authentication → URL Configuration (Site URL & Redirect URLs).

# Backend API (production URL – set in host env or here)
VITE_SERVER_URL=https://paidly-jet.vercel.app

# Supabase – PRODUCTION project only (anon key only; service role never on frontend)
# Dashboard → production project → Settings → API → Project URL + anon public key
VITE_SUPABASE_URL=https://fvxtsbnzadvuttoqcipo.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_eklrqXK-ddMEla7i-ybM8g_jLYh7LuI

# Storage bucket (optional; default: invoicebreek)
VITE_SUPABASE_STORAGE_BUCKET=invoicebreek

{
  "redirects": [
    {
      "source": "/((?!api/).*)",
      "has": [{ "type": "host", "value": "app.paidly.co.za" }],
      "destination": "https://www.paidly.co.za/$1",
      "permanent": true
    },
    {
      "source": "/((?!api/).*)",
      "has": [{ "type": "host", "value": "www.app.paidly.co.za" }],
      "destination": "https://www.paidly.co.za/$1",
      "permanent": true
    },
    {
      "source": "/((?!api/).*)",
      "has": [{ "type": "host", "value": "paidly.co.za" }],
      "destination": "https://www.paidly.co.za/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/affiliate/dashboard",
      "destination": "/api/affiliates?__affiliateDashboard=1"
    },
    {
      "source": "/api/affiliate/dashboard",
      "destination": "/api/affiliates?__affiliateDashboard=1"
    },
    {
      "source": "/api/referrals/create",
      "destination": "/api/affiliates?__referralsCreate=1"
    },
    {
      "source": "/api/cron/payment-reminders",
      "destination": "/api/cron?job=payment-reminders"
    },
    {
      "source": "/api/cron/subscription-dunning",
      "destination": "/api/cron?job=subscription-dunning"
    },
    {
      "source": "/api/cron/subscription-prebill-invoices",
      "destination": "/api/cron?job=subscription-prebill-invoices"
    },
    {
      "source": "/api/cron/admin-broadcast-email",
      "destination": "/api/cron?job=admin-broadcast-email"
    },
    {
      "source": "/api/public-invoice",
      "destination": "/api/public-share?doc=invoice&op=get"
    },
    {
      "source": "/api/public-invoice-verify",
      "destination": "/api/public-share?doc=invoice&op=verify"
    },
    {
      "source": "/api/public-payslip",
      "destination": "/api/public-share?doc=payslip&op=get"
    },
    {
      "source": "/api/public-payslip-verify",
      "destination": "/api/public-share?doc=payslip&op=verify"
    },
    {
      "source": "/api/security/events",
      "destination": "/api/admin/security-events"
    },
    {
      "source": "/api/track-open",
      "destination": "/api/email-track?mode=open"
    },
    {
      "source": "/api/track-link",
      "destination": "/api/email-track?mode=link"
    },
    {
      "source": "/api/payfast/subscription",
      "destination": "/api/payfast-handler?__pf=subscription"
    },
    {
      "source": "/api/payfast/webhook",
      "destination": "/api/payfast-handler?__pf=webhook"
    },
    {
      "source": "/api/payfast/subscription/itn",
      "destination": "/api/payfast-handler?__pf=subscription%2Fitn"
    },
    {
      "source": "/payfast/subscription/itn",
      "destination": "/api/payfast/subscription/itn"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/subscription-dunning",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/cron/subscription-prebill-invoices",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/admin-broadcast-email",
      "schedule": "0 10 * * *"
    }
  ]
}

{
  "redirects": [
    {
      "source": "/((?!api/).*)",
      "has": [{ "type": "host", "value": "app.paidly.co.za" }],
      "destination": "https://www.paidly.co.za/$1",
      "permanent": true
    },
    {
      "source": "/((?!api/).*)",
      "has": [{ "type": "host", "value": "www.app.paidly.co.za" }],
      "destination": "https://www.paidly.co.za/$1",
      "permanent": true
    },
    {
      "source": "/((?!api/).*)",
      "has": [{ "type": "host", "value": "paidly.co.za" }],
      "destination": "https://www.paidly.co.za/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/affiliate/dashboard",
      "destination": "/api/affiliate/dashboard"
    },
    {
      "source": "/api/security/events",
      "destination": "/api/admin/security-events"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "0 8 * * *"
    }
  ]
}

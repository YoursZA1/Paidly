# ===========================================
# Frontend environment variables (Vite)
# ===========================================
# Copy to .env and fill in, or use environment-specific files:
#   .env.development.example → .env.development   (DEV – npm run dev)
#   .env.production.example  → .env.production    (PROD – npm run build)
# Only variables prefixed with VITE_ are exposed to the client.
# Full setup: docs/SUPABASE_SETUP_AND_MAINTENANCE.md

# Backend API base URL (optional; default: http://localhost:5179)
VITE_SERVER_URL=http://localhost:5179

# Supabase (required for auth and storage)
# Use ANON (public) key only. Service role key must NEVER be exposed on frontend (server-only).
# DEV: use dev/staging project. PROD: set VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY correctly in production.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase Storage bucket name (optional; default: invoicebreek)
VITE_SUPABASE_STORAGE_BUCKET=invoicebreek

# Server
# Supabase setup and maintenance: see ../docs/SUPABASE_SETUP_AND_MAINTENANCE.md
PORT=5179
CLIENT_ORIGIN=http://localhost:5173

# Payfast
PAYFAST_MODE=sandbox
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_NOTIFY_URL=http://localhost:5179/api/payfast/itn
PAYFAST_RETURN_URL=http://localhost:5173/AdminSubscriptions
PAYFAST_CANCEL_URL=http://localhost:5173/AdminSubscriptions

# Supabase (server-side only; never use service role key in frontend)
SUPABASE_URL=
# Anon public key (same as VITE_SUPABASE_ANON_KEY on the frontend). Required for POST /api/auth/sign-in IP rate limiting.
SUPABASE_ANON_KEY=

SUPABASE_SERVICE_ROLE_KEY=
ADMIN_BOOTSTRAP_TOKEN=
SUPABASE_STORAGE_BUCKET=paidly
# Allow listed emails to access admin endpoints without app_metadata.role=admin (only when true)
ADMIN_BYPASS_AUTH=false
# Comma-separated emails; only used when ADMIN_BYPASS_AUTH=true
ADMIN_BYPASS_EMAILS=

# Resend (invoice email with PDF attachment)
# Get key from https://resend.com — you must verify your sending domain (e.g. billing@yourdomain.com); cannot send from @gmail.com
RESEND_API_KEY=
RESEND_FROM=Paidly <billing@yourdomain.com>

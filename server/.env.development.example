# Server – DEVELOPMENT
# Copy to server/.env or server/.env.development. Do not commit real values.
# See: ../docs/SUPABASE_SETUP_AND_MAINTENANCE.md

PORT=5179
CLIENT_ORIGIN=http://localhost:5173

# Payfast (sandbox for dev)
PAYFAST_MODE=sandbox
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_NOTIFY_URL=http://localhost:5179/api/payfast/itn
PAYFAST_RETURN_URL=http://localhost:5173/AdminSubscriptions
PAYFAST_CANCEL_URL=http://localhost:5173/AdminSubscriptions

# Supabase – DEV/STAGING project (same as frontend dev)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=invoicebreek
ADMIN_BOOTSTRAP_TOKEN=

# Optional: bypass auth for listed emails (dev only)
ADMIN_BYPASS_AUTH=false
ADMIN_BYPASS_EMAILS=

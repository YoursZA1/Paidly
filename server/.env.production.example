# Server – PRODUCTION
# Set in host env or copy to server/.env.production. Never commit real values.
# Use the same PRODUCTION Supabase project as the frontend.
# See: ../docs/SUPABASE_SETUP_AND_MAINTENANCE.md

PORT=5179
CLIENT_ORIGIN=https://your-app.example.com

# Payfast (live for production)
PAYFAST_MODE=live
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_NOTIFY_URL=https://your-api.example.com/api/payfast/itn
PAYFAST_RETURN_URL=https://your-app.example.com/AdminSubscriptions
PAYFAST_CANCEL_URL=https://your-app.example.com/AdminSubscriptions

# Supabase – PRODUCTION project only
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=paidly
ADMIN_BOOTSTRAP_TOKEN=

# Must be false in production
ADMIN_BYPASS_AUTH=false
ADMIN_BYPASS_EMAILS=

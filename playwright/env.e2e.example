# Copy to repo root as `.env.e2e` (gitignored) and fill in real values.
# Loaded by playwright.admin.config.ts when you run:
#   npm run test:e2e:admin-affiliate
#
# Shell exports still win if the variable is already set.

E2E_ADMIN_EMAIL=your-admin@example.com
E2E_ADMIN_PASSWORD=

E2E_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
E2E_SUPABASE_ANON_KEY=
E2E_SUPABASE_SERVICE_ROLE_KEY=

# Optional: point the Vite dev app at the Node API (can use .env.development instead)
# VITE_SERVER_URL=http://127.0.0.1:5179
